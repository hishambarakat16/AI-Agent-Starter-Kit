# ─── Database ────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=yourpassword
POSTGRES_DB=fintech

# ─── Redis ───────────────────────────────────────────────────────
# Inside Docker the URL is set automatically to redis://redis:6379.
# For local dev running outside Docker, use the mapped host port:
REDIS_URL=redis://localhost:6378

# ─── MCP Server URLs (set automatically in Docker; override for local dev) ───
# MCP_DATA_URL=http://localhost:8051/mcp
# MCP_VECTOR_URL=http://localhost:8052/mcp

# ─── JWT Auth ────────────────────────────────────────────────────
JWT_SECRET_KEY=your-secret-key-minimum-32-characters-long
JWT_ALGORITHM=HS256
JWT_EXPIRES_MIN=60

# ─── OpenAI ──────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Langfuse (optional — for tracing) ───────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ─── Timeouts & Caching ──────────────────────────────────────────
REQUEST_TIMEOUT_SECONDS=60
SEMANTIC_CACHE_DISTANCE_THRESHOLD=0.05
