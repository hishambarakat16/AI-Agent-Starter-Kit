FROM python:3.12-slim

WORKDIR /workspace
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

RUN pip install --no-cache-dir uv

COPY MCP/docker/requirements-mcp.txt /workspace/requirements-mcp.txt

RUN uv venv
RUN uv pip install --system -r /workspace/requirements-mcp.txt

COPY app /workspace/app
COPY MCP /workspace/MCP

ENV PYTHONPATH=/workspace

# download tiktoken cache next (also stable)
ENV TIKTOKEN_CACHE_DIR=/opt/tiktoken_cache
RUN python - <<'PY'
import os, urllib.request
cache_dir = os.environ["TIKTOKEN_CACHE_DIR"]
os.makedirs(cache_dir, exist_ok=True)
PY
# path = os.path.join(cache_dir, "cl100k_base.tiktoken")
# if not (os.path.exists(path) and os.path.getsize(path) > 0):
#     urllib.request.urlretrieve(
#         "https://openaipublic.blob.core.windows.net/encodings/cl100k_base.tiktoken",
#         path
#     )
# print("tiktoken cached:", path)
# PY

EXPOSE 8051

# CMD ["python", "-m", "MCP.server.policy_server"]
